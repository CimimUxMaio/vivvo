<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Vivvo" suffix=" · Property Management & Payments Platform">
      {assigns[:page_title]}
    </.live_title>
    <link
      id="favicon"
      rel="icon"
      type="image/svg+xml"
      data-dark-href={~p"/images/vivvo_favicon_dark.svg"}
      data-light-href={~p"/images/vivvo_favicon_light.svg"}
      sizes="any"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
